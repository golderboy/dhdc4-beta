# Replace hostnames and certificate paths before enabling this file.
# Required modules: rewrite, ssl, headers

ServerTokens Prod
ServerSignature Off
TraceEnable Off

<VirtualHost *:80>
    ServerName dhdc.example.go.th
    Redirect permanent / https://dhdc.example.go.th/
</VirtualHost>

<VirtualHost *:80>
    ServerName dhdc-admin.example.go.th
    Redirect permanent / https://dhdc-admin.example.go.th/
</VirtualHost>

<Directory "/var/www/dhdc4">
    AllowOverride None
    Require all denied
</Directory>

<VirtualHost *:443>
    ServerName dhdc.example.go.th
    DocumentRoot "/var/www/dhdc4/frontend/web"

    SSLEngine on
    SSLCertificateFile "/etc/pki/tls/certs/dhdc.crt"
    SSLCertificateKeyFile "/etc/pki/tls/private/dhdc.key"
    SSLProtocol -all +TLSv1.2 +TLSv1.3
    SSLCipherSuite HIGH:!aNULL:!MD5:!3DES
    SSLHonorCipherOrder on

    <Directory "/var/www/dhdc4/frontend/web">
        Options -Indexes
        AllowOverride All
        Require all granted
    </Directory>

    <DirectoryMatch "^/var/www/dhdc4/frontend/web/(fortythree|fortythreebackup|unzip|sql_upload_file)(/|$)">
        Require all denied
    </DirectoryMatch>

    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    ErrorLog logs/dhdc4-frontend-error.log
    CustomLog logs/dhdc4-frontend-access.log combined
</VirtualHost>

<VirtualHost *:443>
    ServerName dhdc-admin.example.go.th
    DocumentRoot "/var/www/dhdc4/backend/web"

    SSLEngine on
    SSLCertificateFile "/etc/pki/tls/certs/dhdc-admin.crt"
    SSLCertificateKeyFile "/etc/pki/tls/private/dhdc-admin.key"
    SSLProtocol -all +TLSv1.2 +TLSv1.3
    SSLCipherSuite HIGH:!aNULL:!MD5:!3DES
    SSLHonorCipherOrder on

    <Directory "/var/www/dhdc4/backend/web">
        Options -Indexes
        AllowOverride All
        # Keep the administration site behind the hospital network or VPN.
        # Replace these ranges with the approved production source networks.
        <RequireAny>
            Require local
            Require ip 10.0.0.0/8
            Require ip 172.16.0.0/12
            Require ip 192.168.0.0/16
        </RequireAny>
    </Directory>

    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    ErrorLog logs/dhdc4-backend-error.log
    CustomLog logs/dhdc4-backend-access.log combined
</VirtualHost>
