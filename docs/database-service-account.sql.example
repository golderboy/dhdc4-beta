-- Replace host, database name, username and password before execution.
-- This account is intentionally scoped to one database and has no GRANT OPTION.

CREATE USER IF NOT EXISTS 'dhdc_app'@'127.0.0.1'
    IDENTIFIED BY '<generate-a-long-random-password>';

GRANT ALL PRIVILEGES ON `dhdc4`.* TO 'dhdc_app'@'127.0.0.1';

-- Confirm that the resulting grants contain neither *.* nor GRANT OPTION:
SHOW GRANTS FOR 'dhdc_app'@'127.0.0.1';
